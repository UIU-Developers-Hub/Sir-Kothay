# Copy to .env in this folder (server/) and adjust values.

# Django
SECRET_KEY=change-me-in-development-use-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database: omit DB_ENGINE or set sqlite — uses server/db.sqlite3
# For PostgreSQL, set DB_ENGINE and related vars:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=sirkothay_db
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# CORS / CSRF: origins are scheme + host + port (no path). Live Server may use any port.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:3000,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:3000,http://localhost:3000

# About page JSON: GitHub owner/repo for contributor list (optional)
GITHUB_CONTRIBUTORS_REPO=UIU-Developers-Hub/Sir-Kothay

# Client public base URL (no trailing slash): used for QR code links and email deep-links.
# Set to the full URL where the client/ folder is served.
# Example: http://127.0.0.1:5500 (VS Code Live Server, repo root as workspace)
# Example: https://yourdomain.com (production)
CLIENT_PUBLIC_BASE_URL=http://127.0.0.1:5500

# Email (Gmail SMTP — free, 500 emails/day)
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-char password below (no spaces)
# When EMAIL_HOST_USER is set, emails are sent via SMTP.
# When empty, emails print to console (dev mode).
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=abcd efgh ijkl mnop

# GitHub Webhook: shared secret for auto-deployment.
# Must match the secret in your GitHub Webhook settings AND
# the local copy used by the pre-commit hook for encryption.
GITHUB_WEBHOOK_SECRET=CHANGE_ME
ASHAS=ddsfsdf