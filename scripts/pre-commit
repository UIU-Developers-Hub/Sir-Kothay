#!/bin/sh
# Git pre-commit hook: Detect new .env keys and prompt for production values.
# Encrypts them so they travel safely through git to the server.
#
# INSTALL: Run from the repo root:
#   cp scripts/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

ENV_EXAMPLE="server/.env.example"
ENV_KEYS_TRACKER=".env.keys.track"
DEPLOY_FILE=".env.deploy.enc"

# Load webhook secret from local .env (gitignored)
LOCAL_SECRET=""
if [ -f "server/.env" ]; then
    LOCAL_SECRET=$(grep "^GITHUB_WEBHOOK_SECRET=" "server/.env" | cut -d '=' -f 2-)
fi

if [ -z "$LOCAL_SECRET" ]; then
    # No local secret means encryption isn't possible — skip silently
    exit 0
fi

# If .env.example isn't staged, nothing to check
if ! git diff --cached --name-only | grep -q "$ENV_EXAMPLE"; then
    exit 0
fi

# Extract current keys from .env.example (skip comments and blanks)
CURRENT_KEYS=$(grep -v '^\s*#' "$ENV_EXAMPLE" | grep -v '^\s*$' | cut -d '=' -f 1 | sort)

# Load previously known keys
OLD_KEYS=""
if [ -f "$ENV_KEYS_TRACKER" ]; then
    OLD_KEYS=$(cat "$ENV_KEYS_TRACKER" | sort)
fi

# Find NEW keys (in current but not in old)
NEW_KEYS=$(comm -23 <(echo "$CURRENT_KEYS") <(echo "$OLD_KEYS"))

if [ -z "$NEW_KEYS" ]; then
    # Update tracker and exit — no new keys
    echo "$CURRENT_KEYS" > "$ENV_KEYS_TRACKER"
    git add "$ENV_KEYS_TRACKER"
    exit 0
fi

# Check if we can actually read from the user's terminal.
# GitHub Desktop simulates a terminal but blocks input, so we must test reading.
if ! bash -c 'read -t 0 < /dev/tty' 2>/dev/null; then
    echo "======================================================================"
    echo " 🛑 ERROR: New variables were added to server/.env.example"
    echo " GitHub Desktop cannot show interactive terminal prompts."
    echo ""
    echo " Please open your terminal (Command Prompt/PowerShell/VS Code)"
    echo " and run 'git commit' there so you can enter the live server values."
    echo "======================================================================"
    exit 1
fi

echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║  🔑 New environment variables detected!          ║"
echo "║  Enter PRODUCTION values for your server.        ║"
echo "║  Press Enter to skip (use default from example). ║"
echo "╚══════════════════════════════════════════════════╝"
echo ""

PAYLOAD=""
while IFS= read -r key; do
    # Get default from .env.example
    default_val=$(grep "^${key}=" "$ENV_EXAMPLE" | head -1 | cut -d '=' -f 2-)
    
    read -p "  $key [default: $default_val]: " user_val < /dev/tty
    if [ -z "$user_val" ]; then
        user_val="$default_val"
    fi
    PAYLOAD="${PAYLOAD}${key}=${user_val}\n"
done <<< "$NEW_KEYS"

# Encrypt the payload with the webhook secret
echo -e "$PAYLOAD" | openssl enc -aes-256-cbc -pbkdf2 -salt -pass "pass:${LOCAL_SECRET}" -out "$DEPLOY_FILE" 2>/dev/null

# Update the key tracker
echo "$CURRENT_KEYS" > "$ENV_KEYS_TRACKER"

# Stage the encrypted file and tracker
git add "$DEPLOY_FILE" "$ENV_KEYS_TRACKER"

echo ""
echo "  ✅ Encrypted env values saved to $DEPLOY_FILE"
echo "  ✅ Server will auto-decrypt and merge on deploy."
echo ""

exit 0
